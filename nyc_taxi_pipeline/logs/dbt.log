    create or replace table `nyc-taxi-dbt-devia`.`final`.`weekly_revenue`
      
    
    

    
    OPTIONS()
    as (
      SELECT
    CASE EXTRACT(DAYOFWEEK FROM tpep_pickup_datetime)
        WHEN 2 THEN '1-Lundi'
        WHEN 3 THEN '2-Mardi'
        WHEN 4 THEN '3-Mercredi'
        WHEN 5 THEN '4-Jeudi'
        WHEN 6 THEN '5-Vendredi'
