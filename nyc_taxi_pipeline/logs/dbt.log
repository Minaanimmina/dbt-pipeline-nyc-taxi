FROM `nyc-taxi-dbt-devia`.`staging`.`int_trip_metrics`
WHERE EXTRACT(YEAR FROM tpep_pickup_datetime) IN (2024, 2025)
GROUP BY jour_semaine, type_jour
    );
  
